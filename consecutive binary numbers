class Solution:
    def concatenatedBinary(self, n: int) -> int:
        MOD = 10**9 + 7
        ans = 0
        bits = 0

        for i in range(1, n + 1):
            # When i is a power of two, its bit-length increases by 1.
            if i & (i - 1) == 0:
                bits += 1
            ans = ((ans << bits) + i) % MOD

        return ans
